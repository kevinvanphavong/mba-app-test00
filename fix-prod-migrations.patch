From 298716b176c0fb3f768f7a7d33e84907fa1e5adb Mon Sep 17 00:00:00 2001
From: =?UTF-8?q?K=C3=A9vin=20Vanphavong?= <vanphavongk45@gmail.com>
Date: Wed, 22 Apr 2026 18:59:20 +0200
Subject: [PATCH] =?UTF-8?q?fix(prod):=20r=C3=A9pare=20le=20500=20sur=20/ap?=
 =?UTF-8?q?i/auth/login=20cass=C3=A9=20par=20une=20migration=20SQLite-only?=
MIME-Version: 1.0
Content-Type: text/plain; charset=UTF-8
Content-Transfer-Encoding: 8bit

Cause racine: la migration auto-générée Version20260421011520 contient la séquence
DROP TABLE user + CREATE TABLE user (INTEGER PRIMARY KEY AUTOINCREMENT …), syntaxe
SQLite pure. Sur MySQL (prod Railway), le DROP TABLE auto-commit avant que le CREATE
TABLE ne parte en erreur, laissant la base sans table `user`. Tout appel à /api/auth/login
tape alors une table inexistante → 500 systématique, quel que soit l'email envoyé.

Le `|| true` après `doctrine:migrations:migrate` dans l'entrypoint Docker masquait
l'erreur, le container démarrait comme si tout allait bien.

Ce commit:

 - Version20260421011520.php : rend la migration platform-aware. Sur MySQL, no-op
   (les migrations précédentes ont déjà le schéma final). Sur SQLite, comportement
   d'origine inchangé (rebuild des tables pour appliquer les renommages d'index /
   contraintes FK que SQLite ne sait pas modifier via ALTER TABLE).

 - docker/entrypoint.sh : retire `|| true` sur `doctrine:migrations:migrate` pour
   un fail-loud — un schéma cassé doit bloquer le déploiement, pas démarrer en prod
   avec une base corrompue. Ajoute aussi une gate `LOAD_FIXTURES=1` pour piloter
   un `doctrine:fixtures:load --purge-with-truncate` à la demande depuis Railway
   (réensemencement propre de la prod après réparation, puis on remet la var à 0).

 - Dockerfile : remplace l'entrypoint inline (printf multi-ligne illisible qui
   ignorait le fichier du repo) par un COPY docker/entrypoint.sh. Une seule source
   de vérité, auditable.

Plan de remise en route prod:

 1. Railway → MySQL service → ouvrir la console, vérifier le schéma de `user`
    (s'il est absent, DROP DATABASE + recréer la DB).
 2. Railway → variables du service API → poser LOAD_FIXTURES=1.
 3. Déployer cette branche. L'entrypoint va relancer les migrations (toutes
    platform-safe maintenant) puis charger les fixtures Alice.
 4. Remettre LOAD_FIXTURES=0 pour ne pas repurger à chaque redémarrage.
 5. Tester POST /api/auth/login avec kevin@bowlingcentral.fr / shiftly2026.

Reste à faire hors de ce hotfix (branche feat/pointage-validation-hebdo):
 - Rendre Version20260421231657 platform-aware selon le même pattern (la
   branche feature la contient, elle n'est pas encore dans main).
 - Générer les futures migrations avec DATABASE_URL MySQL en local (docker
   compose) pour avoir une sortie native MySQL plutôt que SQLite.

Co-Authored-By: Claude Opus 4.7 (1M context) <noreply@anthropic.com>
---
 shiftly-api/Dockerfile                        |  7 +++--
 shiftly-api/docker/entrypoint.sh              | 17 +++++++++--
 .../migrations/Version20260421011520.php      | 30 ++++++++++++++++---
 3 files changed, 46 insertions(+), 8 deletions(-)

diff --git a/shiftly-api/Dockerfile b/shiftly-api/Dockerfile
index 3e22bdd..10cc56d 100644
--- a/shiftly-api/Dockerfile
+++ b/shiftly-api/Dockerfile
@@ -58,8 +58,11 @@ RUN echo "opcache.enable=1" >> /usr/local/etc/php/conf.d/docker-php-ext-opcache.
 # Supervisor
 COPY docker/supervisord.conf /etc/supervisor/conf.d/supervisord.conf
 
-# Entrypoint inline — évite le cache Docker de Railway
-RUN printf '#!/bin/sh\nset -e\n\nexport APP_ENV=prod\nexport APP_DEBUG=0\n\nACTUAL_PORT="${PORT:-80}"\necho "Port ecoute : $ACTUAL_PORT"\nsed -i "s/NGINX_PORT/$ACTUAL_PORT/" /etc/nginx/nginx.conf\n\nJWT_DIR="/var/www/html/config/jwt"\nmkdir -p "$JWT_DIR"\n\nif [ -n "$JWT_SECRET_KEY_BASE64" ] && [ -n "$JWT_PUBLIC_KEY_BASE64" ]; then\n    echo "$JWT_SECRET_KEY_BASE64" | base64 -d > "$JWT_DIR/private.pem" 2>/dev/null || true\n    echo "$JWT_PUBLIC_KEY_BASE64" | base64 -d > "$JWT_DIR/public.pem" 2>/dev/null || true\nfi\n\nif [ ! -s "$JWT_DIR/private.pem" ]; then\n    openssl genrsa -out "$JWT_DIR/private.pem" 2048 2>/dev/null\n    openssl rsa -in "$JWT_DIR/private.pem" -pubout -out "$JWT_DIR/public.pem" 2>/dev/null\nfi\n\nchown www-data:www-data "$JWT_DIR"/*.pem 2>/dev/null || true\nchmod 600 "$JWT_DIR/private.pem" 2>/dev/null || true\nchmod 644 "$JWT_DIR/public.pem" 2>/dev/null || true\n\nphp /var/www/html/bin/console doctrine:migrations:migrate --no-interaction --allow-no-migration --env=prod 2>&1 || true\n\nchown -R www-data:www-data /var/www/html/var/ 2>/dev/null || true\n\necho "Demarrage sur le port $ACTUAL_PORT..."\nexec /usr/bin/supervisord -c /etc/supervisor/conf.d/supervisord.conf\n' > /entrypoint.sh && chmod +x /entrypoint.sh
+# Entrypoint — source de vérité unique dans docker/entrypoint.sh
+# (avant, le script était défini inline via printf dans le Dockerfile et ignorait
+# le fichier du repo ; désormais les deux sont alignés et le script est auditable.)
+COPY docker/entrypoint.sh /entrypoint.sh
+RUN chmod +x /entrypoint.sh
 
 # Permissions
 RUN mkdir -p var/cache var/log config/jwt \
diff --git a/shiftly-api/docker/entrypoint.sh b/shiftly-api/docker/entrypoint.sh
index be9362a..3c8a16b 100644
--- a/shiftly-api/docker/entrypoint.sh
+++ b/shiftly-api/docker/entrypoint.sh
@@ -34,8 +34,21 @@ chown www-data:www-data "$JWT_DIR"/*.pem 2>/dev/null || true
 chmod 600 "$JWT_DIR/private.pem" 2>/dev/null || true
 chmod 644 "$JWT_DIR/public.pem" 2>/dev/null || true
 
-# Init BDD
-php /var/www/html/bin/console doctrine:migrations:migrate --no-interaction --allow-no-migration --env=prod 2>&1 || true
+# Init BDD — fail-loud : si une migration casse, on bloque le déploiement.
+# Ne JAMAIS rajouter de `|| true` ici : un schéma cassé silencieux (ex. table user droppée
+# par une migration auto-generated SQLite appliquée sur MySQL) provoque des 500 sur le
+# endpoint de login alors que le container démarre comme si tout allait bien.
+echo "Migration du schéma BDD..."
+php /var/www/html/bin/console doctrine:migrations:migrate --no-interaction --allow-no-migration --env=prod
+
+# Réensemencement opt-in — à activer avec LOAD_FIXTURES=1 dans les variables Railway
+# pour une exécution unique, puis à remettre sur 0 sinon les données sont rechargées
+# (et donc écrasées) à chaque redémarrage du container.
+if [ "$LOAD_FIXTURES" = "1" ]; then
+    echo "LOAD_FIXTURES=1 détecté — purge + rechargement des fixtures Alice..."
+    php /var/www/html/bin/console doctrine:fixtures:load --no-interaction --purge-with-truncate --env=prod
+    echo "Fixtures rechargées. N'oublie pas de remettre LOAD_FIXTURES=0 sur Railway."
+fi
 
 chown -R www-data:www-data /var/www/html/var/ 2>/dev/null || true
 
diff --git a/shiftly-api/migrations/Version20260421011520.php b/shiftly-api/migrations/Version20260421011520.php
index abae62b..bdbaeb4 100644
--- a/shiftly-api/migrations/Version20260421011520.php
+++ b/shiftly-api/migrations/Version20260421011520.php
@@ -4,22 +4,39 @@ declare(strict_types=1);
 
 namespace DoctrineMigrations;
 
+use Doctrine\DBAL\Platforms\SqlitePlatform;
 use Doctrine\DBAL\Schema\Schema;
 use Doctrine\Migrations\AbstractMigration;
 
 /**
- * Auto-generated Migration: Please modify to your needs!
+ * Migration auto-générée par Doctrine sur SQLite (dev local).
+ *
+ * IMPORTANT — Platform-aware :
+ *  - Sur MySQL (prod Railway), cette migration est un NO-OP : les migrations précédentes
+ *    (Version20260419000001 pour absence, Version20260418000001 pour planning_snapshot,
+ *    Version20260421000001 pour pointage / pointage_pause / user.code_pointage) ont déjà
+ *    créé ces tables avec leur schéma final. Rejouer des CREATE TEMPORARY/DROP/CREATE en
+ *    syntaxe SQLite sur MySQL casse la base (le DROP TABLE user auto-commit avant que
+ *    le CREATE TABLE user (...AUTOINCREMENT...) ne parte en erreur → table user perdue).
+ *  - Sur SQLite (dev local), on conserve le comportement d'origine : Doctrine régénère
+ *    les tables pour appliquer les renommages d'index / contraintes de clé étrangère
+ *    que SQLite ne peut pas altérer via ALTER TABLE.
  */
 final class Version20260421011520 extends AbstractMigration
 {
     public function getDescription(): string
     {
-        return '';
+        return 'Normalisation des index / FK sur absence, planning_snapshot, pointage, pointage_pause, service, user (SQLite uniquement — no-op MySQL).';
     }
 
     public function up(Schema $schema): void
     {
-        // this up() migration is auto-generated, please modify it to your needs
+        // MySQL (prod) : schéma déjà cohérent via les migrations précédentes — rien à faire.
+        if (!$this->connection->getDatabasePlatform() instanceof SqlitePlatform) {
+            return;
+        }
+
+        // SQLite (dev local) : comportement auto-generated d'origine conservé à l'identique.
         $this->addSql('CREATE TEMPORARY TABLE __temp__absence AS SELECT id, centre_id, user_id, date, type, motif, created_at, created_by FROM absence');
         $this->addSql('DROP TABLE absence');
         $this->addSql('CREATE TABLE absence (id INTEGER PRIMARY KEY AUTOINCREMENT NOT NULL, centre_id INTEGER NOT NULL, user_id INTEGER NOT NULL, date DATE NOT NULL, type VARCHAR(30) NOT NULL, motif VARCHAR(255) DEFAULT NULL, created_at DATETIME NOT NULL, created_by INTEGER DEFAULT NULL, CONSTRAINT FK_absence_centre FOREIGN KEY (centre_id) REFERENCES centre (id) ON UPDATE NO ACTION ON DELETE NO ACTION NOT DEFERRABLE INITIALLY IMMEDIATE, CONSTRAINT FK_absence_user FOREIGN KEY (user_id) REFERENCES user (id) ON UPDATE NO ACTION ON DELETE NO ACTION NOT DEFERRABLE INITIALLY IMMEDIATE, CONSTRAINT FK_absence_created_by FOREIGN KEY (created_by) REFERENCES user (id) ON UPDATE NO ACTION ON DELETE NO ACTION NOT DEFERRABLE INITIALLY IMMEDIATE)');
@@ -71,7 +88,12 @@ final class Version20260421011520 extends AbstractMigration
 
     public function down(Schema $schema): void
     {
-        // this down() migration is auto-generated, please modify it to your needs
+        // MySQL (prod) : up() étant un no-op, down() l'est aussi.
+        if (!$this->connection->getDatabasePlatform() instanceof SqlitePlatform) {
+            return;
+        }
+
+        // SQLite (dev local) : rollback auto-generated d'origine conservé à l'identique.
         $this->addSql('CREATE TEMPORARY TABLE __temp__absence AS SELECT id, date, type, motif, created_at, centre_id, user_id, created_by FROM absence');
         $this->addSql('DROP TABLE absence');
         $this->addSql('CREATE TABLE absence (id INTEGER PRIMARY KEY AUTOINCREMENT NOT NULL, date DATE NOT NULL, type VARCHAR(30) NOT NULL, motif VARCHAR(255) DEFAULT NULL, created_at DATETIME NOT NULL, centre_id INTEGER NOT NULL, user_id INTEGER NOT NULL, created_by INTEGER DEFAULT NULL, CONSTRAINT FK_765AE0C9463CD7C3 FOREIGN KEY (centre_id) REFERENCES centre (id) NOT DEFERRABLE INITIALLY IMMEDIATE, CONSTRAINT FK_765AE0C9A76ED395 FOREIGN KEY (user_id) REFERENCES "user" (id) NOT DEFERRABLE INITIALLY IMMEDIATE, CONSTRAINT FK_765AE0C9DE12AB56 FOREIGN KEY (created_by) REFERENCES "user" (id) NOT DEFERRABLE INITIALLY IMMEDIATE)');
